# Jina Reader — jina.ai のダッシュボードから取得
JINA_API_KEY=

# Gemini — aistudio.google.com から取得
GEMINI_API_KEY=

# Gmail（SMTP）— 送信元アカウントで Google アカウントの「アプリパスワード」を発行し GMAIL_APP_PASSWORD に設定
GMAIL_USER=
GMAIL_APP_PASSWORD=
# 宛先。複数はカンマ区切り（例: a@x.com,b@x.com）
GMAIL_TO=

# モックルート（true にすると RSS は fixtures/sample-rss-tweets.json を読む）
USE_SAMPLE_DATA=false
